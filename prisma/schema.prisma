// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Supabase exposes two connection strings:
  // DATABASE_URL       → pooled (PgBouncer) for serverless short-lived connections (Vercel functions)
  // DIRECT_URL         → non-pooled for Prisma migrations which need persistent sessions
  provider  = "postgresql"
}

// ─── Auth.js / NextAuth required models ──────────────────────────────────────
// These follow the exact schema expected by @auth/prisma-adapter.
// Do NOT rename fields — the adapter maps them by convention.

// This enum defines the two distinct security roles used to segregate staff and management dashboard environments.
enum Role {
  USER_STAFF
  MANAGEMENT_STAFF
}

// This model updates the application database schema to include staff profiles, roles, and a strict connection to their submitted zakat applications.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile and security attributes added for credentials authentication and dashboard authorization
  noPekerja     String?   @unique @map("no_pekerja")
  noKP          String?   @map("no_kp")
  passwordHash  String?   @map("password_hash")
  umur          Int?
  alamatRumah   String?   @db.Text @map("alamat_rumah")
  gajiSemasa    Decimal?  @db.Decimal(10, 2) @map("gaji_semasa")
  role          Role      @default(USER_STAFF)

  accounts                    Account[]
  sessions                    Session[]
  tasks                       Task[]
  zakatStaffSalaryDeductions  ZakatStaffSalaryDeduction[]
}


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  title       String     @db.VarChar(255)
  description String?    @db.Text
  status      TaskStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Each task is owned by an authenticated user — cascading delete keeps DB clean
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])           // Critical: always index FK used in WHERE clauses
  @@index([status, priority]) // Compound index for filtered list queries
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Zakat Salary Deduction Module ────────────────────────────────────────────

enum DeductionType {
  ORIGINAL_PCB_CHANGE  // Perubahan potongan PCB Asal: changes the PCB base + records residual
  FIXED_MONTHLY        // Potongan Zakat Bulanan Sebanyak: a flat recurring monthly deduction
  AMOUNT_ADJUSTMENT    // Penambahan Pengurangan: adjusts deduction from one amount to another
  MATCH_PCB            // Potongan Zakat Mengikut Potongan PCB: zakat mirrors the PCB value exactly
}

enum ApplicationStatus {
  PENDING    // Submitted, awaiting admin review
  APPROVED   // Approved and active for payroll
  REJECTED   // Rejected — staff must resubmit with corrections
}

// This database model stores the official zakat deduction records for UTHM staff.
model ZakatStaffSalaryDeduction {
  id            String            @id @default(cuid())

  // This block stores the personal identification and contact details of the staff member submitting the form.
  namaPenuh     String            @map("nama_penuh")
  noKP          String            @map("no_kp")
  noPekerja     String            @map("no_pekerja")
  noTelefon     String            @map("no_telefon")
  alamatRumah   String            @db.Text @map("alamat_rumah")
  poskod        String            @map("poskod")
  bandar        String            @map("bandar")
  negeri        String            @map("negeri")

  // This block stores the selected payroll deduction mechanism along with optional financial transaction amounts.
  deductionType DeductionType     @map("deduction_type")
  amaunPcbAsal      Decimal? @db.Decimal(10, 2) @map("amaun_pcb_asal")
  amaunZakatBulanan Decimal? @db.Decimal(10, 2) @map("amaun_zakat_bulanan")
  amaunZakatAsal    Decimal? @db.Decimal(10, 2) @map("amaun_zakat_asal")
  amaunZakatBaru    Decimal? @db.Decimal(10, 2) @map("amaun_zakat_baru")

  // This block stores the starting dates and the electronic acceptance of the religious zakat covenant declaration.
  bulanMula         String            @map("bulan_mula")
  tahunMula         String            @map("tahun_mula")
  pengesahanLafaz   Boolean           @default(false) @map("pengesahan_lafaz")

  // This block tracks the submission state, audit timestamps, and administrative evaluation feedback notes.
  status            ApplicationStatus @default(PENDING)
  submittedAt       DateTime          @default(now()) @map("submitted_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  adminNotes        String?           @db.Text @map("admin_notes")

  // This block maps the relation of the submission to the authenticated user account structure.
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([submittedAt(sort: Desc)])

  @@map("zakat_staff_salary_deductions")
}
