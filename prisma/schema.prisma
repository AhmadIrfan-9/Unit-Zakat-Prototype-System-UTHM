// prisma/schema.prisma
//
// Prisma 7: The `url` and `directUrl` properties are NO LONGER supported
// inside the datasource block. Connection URLs now live in `prisma.config.ts`.
// Only `provider` remains here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Supabase PostgreSQL provider.
  // Connection URLs are configured in prisma.config.ts (Prisma 7 requirement).
  provider = "postgresql"
}

// ─── Auth.js / NextAuth required models ──────────────────────────────────────
// These follow the exact schema expected by @auth/prisma-adapter.
// Do NOT rename fields — the adapter maps them by convention.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  tasks                Task[]
  zakatApplications    ZakatApplication[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  title       String     @db.VarChar(255)
  description String?    @db.Text
  status      TaskStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Each task is owned by an authenticated user — cascading delete keeps DB clean
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])           // Critical: always index FK used in WHERE clauses
  @@index([status, priority]) // Compound index for filtered list queries
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Zakat Salary Deduction Module ────────────────────────────────────────────

enum DeductionType {
  ORIGINAL_PCB_CHANGE  // Perubahan potongan PCB Asal
  FIXED_MONTHLY        // Potongan Zakat Bulanan Sebanyak
  AMOUNT_ADJUSTMENT    // Penambahan Pengurangan Potongan Zakat
  MATCH_PCB            // Potongan Zakat Mengikut Potongan PCB
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model ZakatApplication {
  id            String            @id @default(cuid())

  deductionType DeductionType

  originalPcbAmount     Decimal? @db.Decimal(10, 2)
  monthlyZakatDeduction Decimal? @db.Decimal(10, 2)
  residualPcbBalance    Decimal? @db.Decimal(10, 2)

  fixedMonthlyAmount    Decimal? @db.Decimal(10, 2)

  adjustmentFromAmount  Decimal? @db.Decimal(10, 2)
  adjustmentToAmount    Decimal? @db.Decimal(10, 2)

  startMonth            String
  declarationConfirmed  Boolean           @default(false)

  status                ApplicationStatus @default(PENDING)
  submittedAt           DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  adminNotes            String?           @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([submittedAt(sort: Desc)])
}
