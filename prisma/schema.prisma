// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Supabase exposes two connection strings:
  // DATABASE_URL       → pooled (PgBouncer) for serverless short-lived connections (Vercel functions)
  // DIRECT_URL         → non-pooled for Prisma migrations which need persistent sessions
  provider  = "postgresql"
}

// ─── Auth.js / NextAuth required models ──────────────────────────────────────
// These follow the exact schema expected by @auth/prisma-adapter.
// Do NOT rename fields — the adapter maps them by convention.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  tasks                Task[]
  zakatApplications    ZakatApplication[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  title       String     @db.VarChar(255)
  description String?    @db.Text
  status      TaskStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Each task is owned by an authenticated user — cascading delete keeps DB clean
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])           // Critical: always index FK used in WHERE clauses
  @@index([status, priority]) // Compound index for filtered list queries
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Zakat Salary Deduction Module ────────────────────────────────────────────

enum DeductionType {
  ORIGINAL_PCB_CHANGE  // Perubahan potongan PCB Asal: changes the PCB base + records residual
  FIXED_MONTHLY        // Potongan Zakat Bulanan Sebanyak: a flat recurring monthly deduction
  AMOUNT_ADJUSTMENT    // Penambahan Pengurangan: adjusts deduction from one amount to another
  MATCH_PCB            // Potongan Zakat Mengikut Potongan PCB: zakat mirrors the PCB value exactly
}

enum ApplicationStatus {
  PENDING    // Submitted, awaiting admin review
  APPROVED   // Approved and active for payroll
  REJECTED   // Rejected — staff must resubmit with corrections
}

model ZakatApplication {
  id            String            @id @default(cuid())

  // ── Section C: Deduction method chosen by staff ──────────────────────────
  deductionType DeductionType

  // Fields for ORIGINAL_PCB_CHANGE:
  // originalPcbAmount      → the PCB value before modification
  // monthlyZakatDeduction  → the new zakat monthly amount post-change
  // residualPcbBalance     → remaining PCB balance after zakat is carved out
  originalPcbAmount     Decimal? @db.Decimal(10, 2)
  monthlyZakatDeduction Decimal? @db.Decimal(10, 2)
  residualPcbBalance    Decimal? @db.Decimal(10, 2)

  // Field for FIXED_MONTHLY:
  // fixedMonthlyAmount → the absolute RM figure deducted every month
  fixedMonthlyAmount    Decimal? @db.Decimal(10, 2)

  // Fields for AMOUNT_ADJUSTMENT:
  // adjustmentFromAmount → current deduction amount before change
  // adjustmentToAmount   → new target deduction amount after change
  adjustmentFromAmount  Decimal? @db.Decimal(10, 2)
  adjustmentToAmount    Decimal? @db.Decimal(10, 2)

  // ── Section D: Lafaz declaration metadata ──────────────────────────────────
  // startMonth: Malay month+year string e.g. "Januari 2026" — stored as text
  // to faithfully represent the user's declared intent without timezone ambiguity.
  startMonth            String

  // declarationConfirmed: must be true before submission is accepted;
  // the physical form requires explicit staff acknowledgement of the lafaz.
  declarationConfirmed  Boolean           @default(false)

  // ── Application lifecycle ──────────────────────────────────────────────────
  status                ApplicationStatus @default(PENDING)
  submittedAt           DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  adminNotes            String?           @db.Text // Optional rejection/approval note from admin

  // ── Ownership ─────────────────────────────────────────────────────────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])                  // All queries filter by owner first
  @@index([status])                  // Admin review dashboard filters by status
  @@index([userId, status])          // Compound for user-scoped status views
  @@index([submittedAt(sort: Desc)]) // Chronological ordering for audit trail
}
